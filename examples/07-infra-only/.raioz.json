{
  "schemaVersion": "1.0",
  "network": "infra-network",
  "project": {
    "name": "shared-infra",
    "commands": {
      "up": "echo 'Shared infrastructure is ready'",
      "down": "echo 'Shared infrastructure stopped'"
    }
  },
  "services": {},
  "infra": {
    "postgres": {
      "image": "postgres",
      "tag": "15-alpine",
      "ports": ["5433:5432"],
      "volumes": ["pg-data:/var/lib/postgresql/data"],
      "seed": ["seeds/init.sql"],
      "env": {
        "POSTGRES_PASSWORD": "dev123",
        "POSTGRES_DB": "shared"
      }
    },
    "redis": {
      "image": "redis",
      "tag": "7-alpine",
      "ports": ["6379:6379"]
    },
    "mongo": {
      "image": "mongo",
      "tag": "7",
      "ports": ["27017:27017"],
      "volumes": ["mongo-data:/data/db"]
    }
  },
  "env": {
    "useGlobal": true,
    "files": ["global"],
    "variables": {
      "ENVIRONMENT": "development",
      "LOG_LEVEL": "debug"
    }
  }
}
