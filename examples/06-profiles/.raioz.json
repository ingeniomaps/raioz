{
  "schemaVersion": "1.0",
  "network": "profiles-network",
  "project": {
    "name": "profiles-demo"
  },
  "services": {
    "frontend": {
      "source": {
        "kind": "image",
        "image": "nginx",
        "tag": "alpine"
      },
      "docker": {
        "mode": "prod",
        "ports": ["3000:80"]
      },
      "profiles": ["frontend"]
    },
    "api": {
      "source": {
        "kind": "image",
        "image": "hashicorp/http-echo",
        "tag": "latest"
      },
      "docker": {
        "mode": "prod",
        "ports": ["3001:5678"],
        "command": "-text='api response'"
      },
      "profiles": ["backend"]
    },
    "worker": {
      "source": {
        "kind": "image",
        "image": "busybox",
        "tag": "latest"
      },
      "docker": {
        "mode": "prod",
        "command": "sh -c 'while true; do echo worker running; sleep 30; done'"
      },
      "profiles": ["backend"]
    }
  },
  "infra": {
    "postgres": {
      "image": "postgres",
      "tag": "15-alpine",
      "ports": ["5434:5432"],
      "volumes": ["pg-data:/var/lib/postgresql/data"],
      "env": {
        "POSTGRES_PASSWORD": "dev123",
        "POSTGRES_DB": "app"
      }
    }
  },
  "env": {
    "useGlobal": true,
    "files": ["global"]
  }
}
