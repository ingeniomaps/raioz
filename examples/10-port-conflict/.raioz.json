{
  "schemaVersion": "1.0",
  "network": "conflict-network",
  "project": {
    "name": "conflict-demo"
  },
  "services": {
    "api": {
      "source": {
        "kind": "image",
        "image": "hashicorp/http-echo",
        "tag": "latest"
      },
      "docker": {
        "mode": "prod",
        "ports": ["3001:5678"],
        "command": "-text='conflict api'"
      }
    }
  },
  "infra": {},
  "env": {
    "useGlobal": true,
    "files": ["global"]
  }
}
