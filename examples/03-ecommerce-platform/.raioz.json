{
  "schemaVersion": "1.0",
  "project": {
    "name": "ecommerce-platform",
    "network": "ecommerce-network"
  },
  "env": {
    "useGlobal": true,
    "files": ["global"]
  },
  "services": {
    "frontend": {
      "source": {
        "kind": "git",
        "repo": "https://github.com/vercel/commerce.git",
        "branch": "main",
        "path": "."
      },
      "docker": {
        "mode": "dev",
        "ports": ["3000:3000"],
        "command": "npm run dev",
        "runtime": "node",
        "dependsOn": ["api"]
      },
      "env": ["services/frontend"]
    },
    "api": {
      "source": {
        "kind": "git",
        "repo": "https://github.com/medusajs/medusa.git",
        "branch": "develop",
        "path": "packages/medusa"
      },
      "docker": {
        "mode": "dev",
        "ports": ["8000:9000"],
        "command": "npm run dev",
        "runtime": "node",
        "dependsOn": ["auth", "database"]
      },
      "env": ["services/api"]
    },
    "auth": {
      "source": {
        "kind": "git",
        "repo": "https://github.com/nextauthjs/next-auth.git",
        "branch": "main",
        "path": "."
      },
      "docker": {
        "mode": "dev",
        "ports": ["8001:3000"],
        "command": "npm run dev",
        "runtime": "node",
        "dependsOn": ["database", "redis"]
      },
      "env": ["services/auth"]
    },
    "payments": {
      "source": {
        "kind": "git",
        "repo": "https://github.com/stripe/stripe-node.git",
        "branch": "master",
        "path": "examples"
      },
      "docker": {
        "mode": "dev",
        "ports": ["8002:3000"],
        "command": "npm start",
        "runtime": "node",
        "dependsOn": ["database", "redis"]
      },
      "env": ["services/payments"]
    },
    "notifications": {
      "source": {
        "kind": "git",
        "repo": "https://github.com/OptimalBits/bull.git",
        "branch": "master",
        "path": "examples"
      },
      "docker": {
        "mode": "dev",
        "ports": ["8003:3000"],
        "command": "npm start",
        "runtime": "node",
        "dependsOn": ["redis", "rabbitmq"]
      },
      "env": ["services/notifications"]
    }
  },
  "infra": {
    "database": {
      "image": "postgres",
      "tag": "15-alpine",
      "ports": ["5432:5432"],
      "volumes": ["postgres-data:/var/lib/postgresql/data"],
      "env": ["infra/database"]
    },
    "redis": {
      "image": "redis",
      "tag": "7-alpine",
      "ports": ["6379:6379"],
      "volumes": ["redis-data:/data"]
    },
    "rabbitmq": {
      "image": "rabbitmq",
      "tag": "3-management-alpine",
      "ports": ["5672:5672", "15672:15672"],
      "volumes": ["rabbitmq-data:/var/lib/rabbitmq"]
    }
  }
}
