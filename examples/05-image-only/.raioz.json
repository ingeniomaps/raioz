{
  "schemaVersion": "1.0",
  "network": "image-only-network",
  "project": {
    "name": "image-only"
  },
  "services": {
    "web": {
      "source": {
        "kind": "image",
        "image": "nginx",
        "tag": "alpine"
      },
      "docker": {
        "mode": "prod",
        "ports": ["8080:80"]
      }
    },
    "api": {
      "source": {
        "kind": "image",
        "image": "hashicorp/http-echo",
        "tag": "latest"
      },
      "docker": {
        "mode": "prod",
        "ports": ["5678:5678"],
        "command": "-text='hello from raioz'"
      }
    }
  },
  "infra": {
    "redis": {
      "image": "redis",
      "tag": "7-alpine",
      "ports": ["6379:6379"]
    }
  },
  "env": {
    "useGlobal": true,
    "files": ["global"]
  }
}
