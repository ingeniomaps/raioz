{
  "schemaVersion": "1.0",
  "network": "git-services-network",
  "project": {
    "name": "git-services-demo"
  },
  "services": {
    "hello": {
      "source": {
        "kind": "git",
        "repo": "https://github.com/crccheck/docker-hello-world.git",
        "branch": "master",
        "path": "services/hello",
        "access": "readonly"
      },
      "docker": {
        "mode": "prod",
        "dockerfile": "Dockerfile",
        "ports": ["8010:8000"]
      }
    },
    "welcome": {
      "source": {
        "kind": "git",
        "repo": "https://github.com/docker/welcome-to-docker.git",
        "branch": "main",
        "path": "services/welcome",
        "access": "editable"
      },
      "docker": {
        "mode": "dev",
        "dockerfile": "Dockerfile",
        "ports": ["3010:80"]
      }
    }
  },
  "infra": {
    "redis": {
      "image": "redis",
      "tag": "7-alpine",
      "ports": ["6381:6379"]
    }
  },
  "env": {
    "useGlobal": true,
    "files": ["global"]
  }
}
