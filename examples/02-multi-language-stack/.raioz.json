{
  "schemaVersion": "1.0",
  "project": {
    "name": "multi-language-stack",
    "network": "multilang-network"
  },
  "env": {
    "useGlobal": true,
    "files": ["global"]
  },
  "services": {
    "go-api": {
      "source": {
        "kind": "git",
        "repo": "https://github.com/gin-gonic/examples.git",
        "branch": "master",
        "path": "realworld"
      },
      "docker": {
        "mode": "dev",
        "ports": ["8080:8080"],
        "command": "go run main.go",
        "runtime": "go",
        "dependsOn": ["database"]
      },
      "env": ["services/go-api"]
    },
    "node-service": {
      "source": {
        "kind": "git",
        "repo": "https://github.com/typicode/json-server.git",
        "branch": "main",
        "path": "."
      },
      "docker": {
        "mode": "dev",
        "ports": ["3000:3000"],
        "command": "npm start",
        "runtime": "node",
        "dependsOn": ["go-api", "redis"]
      },
      "env": ["services/node-service"]
    },
    "python-worker": {
      "source": {
        "kind": "git",
        "repo": "https://github.com/tiangolo/fastapi.git",
        "branch": "master",
        "path": "."
      },
      "docker": {
        "mode": "dev",
        "ports": ["8000:8000"],
        "command": "uvicorn main:app --reload",
        "runtime": "python",
        "dependsOn": ["redis", "rabbitmq"]
      },
      "env": ["services/python-worker"]
    },
    "rust-processor": {
      "source": {
        "kind": "git",
        "repo": "https://github.com/actix/examples.git",
        "branch": "master",
        "path": "basics"
      },
      "docker": {
        "mode": "dev",
        "ports": ["8081:8080"],
        "command": "cargo run",
        "runtime": "rust",
        "dependsOn": ["database"]
      },
      "env": ["services/rust-processor"]
    }
  },
  "infra": {
    "database": {
      "image": "postgres",
      "tag": "15-alpine",
      "ports": ["5432:5432"],
      "volumes": ["postgres-data:/var/lib/postgresql/data"],
      "env": ["infra/database"]
    },
    "redis": {
      "image": "redis",
      "tag": "7-alpine",
      "ports": ["6379:6379"],
      "volumes": ["redis-data:/data"]
    },
    "rabbitmq": {
      "image": "rabbitmq",
      "tag": "3-management-alpine",
      "ports": ["5672:5672", "15672:15672"],
      "volumes": ["rabbitmq-data:/var/lib/rabbitmq"]
    }
  }
}
