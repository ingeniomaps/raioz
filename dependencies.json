{
  "schemaVersion": "1.0",

  "project": {
    "name": "billing-dashboard",
    "namespace": "cubiko",
    "network": "cubiko"
  },

  "env": {
    "useGlobal": true,
    "files": ["global", "projects/billing-dashboard"]
  },

  "services": {
    "users-service": {
      "type": "microservice",
      "runtime": "node",
      "source": {
        "kind": "git",
        "repo": "git@github.com:raioz/users-service.git",
        "branch": "feature/auth-refactor",
        "path": "services/users-service"
      },
      "docker": {
        "mode": "dev",
        "dockerfile": "Dockerfile.dev",
        "context": ".",
        "ports": ["3001:3000"],
        "volumes": ["./:/app"],
        "dependsOn": ["mongo"]
      },
      "env": ["services/users-service"]
    },

    "payments-service": {
      "type": "microservice",
      "runtime": "go",
      "source": {
        "kind": "image",
        "image": "raioz/payments-service",
        "tag": "1.3.2"
      },
      "docker": {
        "mode": "prod",
        "ports": ["3002:3000"],
        "dependsOn": ["rabbit"]
      },
      "env": ["services/payments-service"]
    }
  },

  "infra": {
    "mongo": {
      "type": "database",
      "image": "mongo",
      "tag": "6.0",
      "ports": ["27017:27017"],
      "volumes": ["mongo-data:/data/db"],
      "env": ["infra/mongo"]
    },

    "redis": {
      "type": "cache",
      "image": "redis",
      "tag": "7",
      "ports": ["6379:6379"]
    },

    "rabbit": {
      "type": "queue",
      "image": "rabbitmq",
      "tag": "3-management",
      "ports": ["5672:5672", "15672:15672"]
    }
  }
}
